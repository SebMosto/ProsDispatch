# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Your Supabase project URL (found in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://nctjhybvdkmyxanqiphi.supabase.co

# Your Supabase anonymous/public key (found in Supabase Dashboard > Settings > API)
# Use the modern publishable key (sb_publishable_...) if available, or the legacy anon key
VITE_SUPABASE_ANON_KEY=sb_publishable_RruFiqaFPwocf0l2KJWdEg_klQ1n39O

# Stripe Configuration
# Your Stripe publishable key (found in Stripe Dashboard > Developers > API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Edge Functions Environment Variables
# These are configured in Supabase Dashboard > Edge Functions > Settings
# Or via CLI: supabase secrets set VARIABLE_NAME=value

# Stripe Secret Key (found in Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (found in Stripe Dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase Service Role Key (found in Supabase Dashboard > Settings > API)
# WARNING: This key bypasses Row Level Security. Never expose it client-side!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Supabase URL (same as VITE_SUPABASE_URL, used by Edge Functions)
SUPABASE_URL=https://nctjhybvdkmyxanqiphi.supabase.co

# Supabase Anonymous Key (same as VITE_SUPABASE_ANON_KEY, used by Edge Functions)
SUPABASE_ANON_KEY=sb_publishable_RruFiqaFPwocf0l2KJWdEg_klQ1n39O
