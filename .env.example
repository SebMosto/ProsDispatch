# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Your Supabase project URL (found in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public key (found in Supabase Dashboard > Settings > API)
# Use the modern publishable key (sb_publishable_...) if available, or the legacy anon key
VITE_SUPABASE_ANON_KEY=sb_publishable_RruFiqaFPwocf0l2KJWdEg_klQ1n39O

# Stripe Configuration
# Your Stripe publishable key (found in Stripe Dashboard > Developers > API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51Sp7yyL7ioFFaVuv97FfsfoCBPQrKMlshmATMHwVAz7jBCO8is9fznhoQ7WKTqwNeGOLKxrvvMBuFu8hFq78c31o00D2QtLufr
STRIPE_SECRET_KEY=sk_test_51Sp7yyL7ioFFaVuv27T8SxXsAiLyXRt1jXTSFN3vNjBYCxLeYXenYh6o3K8XaoLN1xkVpUEciNycWk58rTgN9tuu006BY0EkbA
# STRIPE_WEBHOOK_SECRET=whsec_0bc30297f5eee86d41b3da759cb044512e54dc8b0096e7c8b7b8d5ef5a06a277

# Security Configuration
# The URL of your site (used for validating redirects)
SITE_URL=http://localhost:3000

# Feature Flags
# Set to 'true' in Vercel env vars (Production + Preview) to re-enable subscription gate post-pilot
VITE_SUBSCRIPTION_GATE_ENABLED=false

# Invoice finalize (edge function: finalize-and-send-invoice)
# Set these in Supabase Dashboard → Edge Functions → Secrets (not Vite env):
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, SITE_URL
# The handler calls generate-invoice-pdf via POST {SITE_URL}/functions/v1/generate-invoice-pdf
# with the service role; deploy both functions and ensure SITE_URL matches your app origin.
#
# Local preview / Playwright E2E (vite build + vite preview): `import.meta.env.DEV` is false, so
# the dev-only client fallback does not run unless you set this at BUILD time:
#   VITE_ALLOW_INVOICE_FINALIZE_FALLBACK=true
# Never set VITE_ALLOW_INVOICE_FINALIZE_FALLBACK in Vercel Production — it enables a DB-only path
# when the edge function errors (same as local npm run dev). Default: omit (unsafe fallback off).
# VITE_ALLOW_INVOICE_FINALIZE_FALLBACK=
